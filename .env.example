# NextAuth – obavezno za rad prijave i sesije
# Lokalno: postavite na URL na kojem aplikacija radi (npr. http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-min-32-chars-long-random-string

# App URL (za linkove u e-mailu, npr. Passwort zurücksetzen). Lokalni dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend – za slanje e-mailova (Passwort vergessen). API key na https://resend.com
RESEND_API_KEY=
# Opcionalno: from adresa (npr. noreply@vasa-domena.at). Ako nije postavljena, koristi se onboarding@resend.dev
# RESEND_FROM_EMAIL=

# Baza (Prisma) – PostgreSQL / Neon
#
# Neon (preporuka za serverless / Vercel):
# 1) U Neon Dashboard: Branch mora biti aktivan (free tier gasi bazu nakon neaktivnosti – otvori projekt da se „probudi”).
# 2) Connection string: koristi „Pooled“ / „Transaction“ URL za DATABASE_URL (host sadrži -pooler.).
# 3) Na kraju URL-a dodaj npr.: ?sslmode=require&connect_timeout=15
#    Primjer: postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=5
# 4) DIRECT_URL = „Direct“ (bez pooler-a) – obavezno za `prisma migrate` / `db push`.
# 5) Ako si rotirao lozinku u Neonu, ažuriraj obje varijable na Vercelu i napravi Redeploy.
#
DATABASE_URL=postgresql://user:password@localhost:5432/mcdtoolat
DIRECT_URL=postgresql://user:password@localhost:5432/mcdtoolat

# Vercel Blob (potpisi, uploadi)
BLOB_READ_WRITE_TOKEN=

# Training: gemeinsames Passwort für Gastzugriff auf /training (ohne Benutzerkonto)
# Lokal (`npm run dev`): Ohne diese Zeile oder leer → API nutzt 1234; zusätzlich akzeptiert die API
# in der Entwicklung immer 1234 (auch wenn hier ein anderes Passwort steht).
# Empfohlen zum Testen: TRAINING_GUEST_PASSWORD=1234
# WICHTIG: Für aiw.services / Vercel Production Variable unter Vercel → Environment Variables setzen.
TRAINING_GUEST_PASSWORD=

# CL Analyse: Passwort für den Zugang zum Finanz-Controlling-Modul (/admin/finanz/cl-analyse).
# Wenn leer oder nicht gesetzt, gilt der Standardwert "zoran123".
# Für Produktion (Vercel): unter Environment Variables setzen.
CL_ANALYSE_PASSWORD=zoran123

# Training: feste User-ID für Lars (Benachrichtigungen bei Teilnehmer-Bewertung).
# Optional: wenn leer, wird der Account lars.hoffmann@aiw.at gesucht (Seed).
TRAINING_LARS_USER_ID=

# --- Vercel (produkcija) ---
# U projektu na Vercelu dodaj sve varijable iz ovog primjera (s pravim vrijednostima).
# Za Production postavi NEXTAUTH_URL na https://www.aiw.services.
# Potrebne uključujući: DATABASE_URL, DIRECT_URL, NEXTAUTH_SECRET, NEXTAUTH_URL, BLOB_READ_WRITE_TOKEN, RESEND_API_KEY, TRAINING_GUEST_PASSWORD.
