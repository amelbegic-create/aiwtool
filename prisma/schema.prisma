generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Za Neon/pool: u DATABASE_URL dodaj ?connection_limit=5 da ne iscrpiš pool (npr. Neon limit 10)
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")    // Direct connection (OBAVEZNO za 'prisma db push')
}

// --- ENUMS ---
enum Role {
  SYSTEM_ARCHITECT
  ADMIN
  MANAGER
  MANAGEMENT
  MITARBEITER
}

enum PDSStatus {
  DRAFT
  IN_PROGRESS
  OPEN
  SUBMITTED
  RETURNED
  APPROVED
  COMPLETED
  ARCHIVED
}

// ENUMI ZA PRAVILA
enum RulePriority {
  INFORMATION
  MANDATORY
  URGENT
}

enum RuleStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

// --- BONUS TOOL ENUMS ---
enum BonusCycleStatus {
  DRAFT      // Konfiguracija u toku
  ACTIVE     // Trenutni obračunski ciklus
  CLOSED     // Zaključan, ali vidljiv za izvještaje
  ARCHIVED   // Arhiviran, read-only
}

enum BonusFactorMode {
  MULTIPLY
  AVERAGE
}

enum DashboardNewsAttachmentKind {
  PDF
  IMAGE
  VIDEO
}

// --- DEPARTMENTS (Odjeli) ---
model Department {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("#6b7280") // HEX npr. #ff0000
  sortOrder    Int      @default(0)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  users        User[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([restaurantId])
  @@index([sortOrder])
}

// --- VORLAGEN (Templates) ---
model TemplateCategory {
  id          String         @id @default(cuid())
  name        String
  description String?
  iconName    String?
  sortOrder   Int            @default(0)
  templates   TemplateItem[]
  createdAt   DateTime       @default(now())

  @@index([sortOrder])
}

model TemplateItem {
  id             String           @id @default(cuid())
  title          String
  description    String?
  fileUrl        String
  fileType       String
  extractedText  String?          @db.Text // Tekst iz PDF-a za pretragu (ne skenirani PDF)
  categoryId     String
  category       TemplateCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([categoryId])
}

// --- INFORMATIONEN ---
model InformationCategory {
  id          String              @id @default(cuid())
  name        String
  description String?
  iconName    String?
  sortOrder   Int                 @default(0)
  items       InformationItem[]
  createdAt   DateTime            @default(now())

  @@index([sortOrder])
}

model InformationItem {
  id             String              @id @default(cuid())
  title          String
  description    String?
  fileUrl        String
  fileType       String
  extractedText  String?             @db.Text
  categoryId     String
  category       InformationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())

  @@index([categoryId])
}

// --- BESUCHSBERICHTE (pro Restoran, po godinama) ---
model VisitReportCategory {
  id           String            @id @default(cuid())
  name         String
  description  String?
  iconName     String?
  sortOrder    Int               @default(0)
  restaurantId String
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        VisitReportItem[]
  createdAt    DateTime          @default(now())

  @@index([restaurantId])
  @@index([restaurantId, sortOrder])
}

model VisitReportItem {
  id            String              @id @default(cuid())
  title         String
  description   String?
  fileUrl       String
  fileType      String
  extractedText String?             @db.Text // Tekst iz PDF-a za pretragu (samo PDF)
  categoryId    String
  category      VisitReportCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  year          Int
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())

  @@index([categoryId, year])
  @@index([categoryId, sortOrder])
}

// --- AIW KALENDER (custom events) ---
model CalendarEventCategory {
  id        String   @id @default(cuid())
  name      String
  color     String?  // optional hex e.g. #FFBC0D
  sortOrder Int?     // optional for display order
  events    CalendarEvent[]

  @@index([sortOrder])
}

model CalendarPersonalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  title     String
  color     String?  // optional hex e.g. #FFBC0D
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, date])
  @@index([userId, date, sortOrder])
}

model CalendarEvent {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardNewsItemId String?
  dashboardNewsItem   DashboardNewsItem? @relation(fields: [dashboardNewsItemId], references: [id], onDelete: Cascade)
  title      String
  date       DateTime
  endDate    DateTime? // optional: multi-day event
  type       String    // legacy: "personal" | "shift" | "vacation"; new: from category.name or "custom"
  color      String?   // optional: hex e.g. #FFBC0D for custom (praznik, etc.)
  categoryId String?
  category   CalendarEventCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([userId, date])
  @@index([categoryId])
  @@index([dashboardNewsItemId])
}

// --- TO-DO LIST ---
model Todo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  priority  Int      @default(2) // 1=high, 2=medium, 3=low
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- USERS & AUTH ---
model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  password            String?
  role                Role      @default(MITARBEITER)
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  isActive            Boolean   @default(true)
  image               String?
  lastSeen            DateTime? @default(now())
  permissions         String[]  @default([])
  vacationEntitlement Int       @default(20)
  vacationCarryover   Int       @default(0)

  // Nadređeni (za Mein Team i odobravanje godišnjeg)
  supervisorId        String?
  supervisor          User?     @relation("UserSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  subordinates        User[]    @relation("UserSupervisor")

  // Godišnji po godinama (VacationAllowance = dinamička lista godina)
  vacationAllowances  VacationAllowance[]

  restaurants              RestaurantUser[]
  evaluations         EvaluationSubmission[]
  vacations           VacationRequest[]      // zahtjevi koje je korisnik kreirao
  supervisedVacations VacationRequest[] @relation("VacationSupervisor") // ✅ NOVO: zahtjevi koji dolaze ovom korisniku na odobrenje

  pdsList             PDS[]
  accounts            Account[]
  sessions            Session[]

  // RELACIJE ZA PRAVILA
  readRules           RuleReadReceipt[]

  // ✅ NOVO: state snapshotovi za alate (Vercel Blob pointeri)
  toolStates          ToolState[]

  // BONUS TOOL: zapisi po bonus ciklusu
  bonusEntries        BonusEntry[]

  dashboardChangelogUpdates DashboardChangelog[]

  ideaSubmissions      Idea[] @relation("IdeaSubmission")
  ideaAdminReplies     Idea[] @relation("IdeaAdminReply")
  certificates         UserCertificate[]
  calendarEvents       CalendarEvent[]
  calendarPersonalEntries CalendarPersonalEntry[]
  todos                Todo[]

  laborReportsClLockedBy          LaborReport[] @relation("LaborReportLockedBy")
  laborReportsClUnlockRequestedBy LaborReport[] @relation("LaborReportUnlockRequestedBy")
  laborReportsClEditGrant         LaborReport[] @relation("LaborReportEditGrant")

  /** Pročitane in-app notifikacije (ključ = NotificationItem.id iz notificationActions) */
  notificationReads               NotificationRead[]

  helpRequestsCreated             HelpRequest[]     @relation("HelpRequestCreatedBy")
  helpSlotsAsProviderManager      HelpSlot[]        @relation("HelpSlotProviderManager")

  // Activity tracking for dashboard popup views
  dashboardNewsViews            DashboardNewsView[]
  dashboardEventViews           DashboardEventView[]
  dashboardEventLikes           DashboardEventLike[]
  dashboardEventComments        DashboardEventComment[]

  trainingParticipants          TrainingParticipant[]
  trainingParticipantAssessments TrainingParticipant[] @relation("TrainingParticipantAssessedBy")

  partnerCompanyComments        PartnerCompanyComment[] @relation("PartnerCompanyCommentAuthor")

  oneOnOneTopics         OneOnOneTopic[] @relation("TopicRequester")
  supervisedTopics       OneOnOneTopic[] @relation("TopicSupervisor")
  oneOnOneComments       OneOnOneComment[] @relation("OneOnOneCommentAuthor")
  oneOnOneAttachments    OneOnOneAttachment[] @relation("OneOnOneAttachmentUploader")

  conversations          OneOnOneConversation[] @relation("ConversationRequester")
  supervisedConversations OneOnOneConversation[] @relation("ConversationSupervisor")
  archivedConversations  OneOnOneConversation[] @relation("ConversationArchivedBy")
  conversationAttachments OneOnOneConversationAttachment[] @relation("ConversationAttachmentUploader")
  conversationItemComments OneOnOneConversationItemComment[] @relation("ConversationItemCommentAuthor")
  conversationTodosCreated OneOnOneConversationTodoItem[] @relation("ConversationTodoCreatedBy")
  conversationsCreated    OneOnOneConversation[] @relation("ConversationCreatedBy")
  conversationItemsCreated OneOnOneConversationItem[] @relation("ConversationItemCreatedBy")

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// --- Vorlagen: feste Schulungsinhalte (8 Standardprogramme) ---
model TrainingTemplate {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  topics         String?           @db.Text
  prerequisites  String?           @db.Text
  sortOrder      Int               @default(0)
  programs       TrainingProgram[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([sortOrder])
}

// --- SCHULUNGEN (Trainingsplan, öffentlich / Gast-Passwort / Admin-CRUD) ---
model TrainingProgram {
  id             String            @id @default(cuid())
  title          String
  description    String?           @db.Text
  /** Inhalte / Themen (mehrzeilig, wie Excel-Spalte) */
  topics         String?           @db.Text
  /** Voraussetzungen */
  prerequisites  String?           @db.Text
  /** z. B. „1 Tag / #107“ oder „2 Tage / #004 + #156“ */
  scheduleMeta   String?
  sortOrder      Int               @default(0)
  isActive       Boolean           @default(true)
  templateId     String?
  template       TrainingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  restaurants    TrainingProgramRestaurant[]
  sessions       TrainingSession[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@index([templateId])
}

model TrainingSession {
  id           String                 @id @default(cuid())
  programId    String
  program      TrainingProgram        @relation(fields: [programId], references: [id], onDelete: Cascade)
  title        String?
  startsAt     DateTime
  endsAt       DateTime?
  location     String?
  notes        String?                @db.Text
  sortOrder    Int                    @default(0)
  participants TrainingParticipant[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([programId])
  @@index([programId, sortOrder])
  @@index([startsAt])
}

model TrainingParticipant {
  id           String          @id @default(cuid())
  sessionId    String
  session      TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName    String?
  lastName     String?
  /** Anzeigereihenfolge (01., 02., …) */
  displayOrder Int             @default(0)
  /** z. B. „156“ für „(#156)“ */
  badgeCode    String?
  /** Nachkurs: Bewertung durch Trainer */
  courseComment     String?    @db.Text
  /** Ergebnis 0–100 % */
  resultPercent     Int?
  assessedByUserId  String?
  assessedBy        User?      @relation("TrainingParticipantAssessedBy", fields: [assessedByUserId], references: [id], onDelete: SetNull)
  assessedAt        DateTime?

  createdAt    DateTime        @default(now())

  @@index([sessionId])
  @@index([sessionId, displayOrder])
  @@index([userId])
  @@index([assessedAt])
}

model NotificationRead {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifKey  String   @db.VarChar(512)
  readAt    DateTime @default(now())

  @@unique([userId, notifKey])
  @@index([userId])
}

enum IdeaStatus {
  SENT
  IN_PROGRESS
  DONE
}

// Ideenbox: Vorschläge von Mitarbeitern an System Architect / AL
model Idea {
  id             String     @id @default(cuid())
  text           String     @db.Text
  userId         String
  user           User       @relation("IdeaSubmission", fields: [userId], references: [id], onDelete: Cascade)
  isRead         Boolean    @default(false)
  /** Admin arhiva – ne prikazuje se u aktivnom pregledu ni u notifikacijama */
  isArchived     Boolean    @default(false)
  createdAt      DateTime   @default(now())

  /** Bearbeitungsstatus für den Einreicher sichtbar */
  status         IdeaStatus @default(SENT)
  /** Antwort des Teams / Admins */
  adminReply     String?    @db.Text
  repliedAt      DateTime?
  repliedById    String?
  repliedBy      User?      @relation("IdeaAdminReply", fields: [repliedById], references: [id], onDelete: SetNull)

  // Legacy: jedan prilog (slika ili PDF)
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  attachmentSize Int?

  // Novo: više slika + jedan PDF
  imageUrls      String[] @default([])
  imageNames     String[] @default([])
  pdfUrl         String?
  pdfName        String?
  pdfSize        Int?

  @@index([userId])
  @@index([isRead])
  @@index([isArchived])
  @@index([status])
}

// Zertifikate, Kurse und Schulungen pro Mitarbeiter
model UserCertificate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String   @db.Text

  pdfUrl      String?
  pdfName     String?
  pdfSize     Int?

  imageUrl    String?
  imageName   String?
  imageSize   Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
}

model VacationAllowance {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  year            Int
  days            Int      @default(0)
  carriedOverDays Int      @default(0) // Preneseno iz prethodne godine

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, year])
  @@index([year])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

// Ein Eintrag: Aktuelle Änderungen auf dem Dashboard (ADMIN / SUPER_ADMIN / SYSTEM_ARCHITECT dürfen bearbeiten).
model DashboardChangelog {
  id          String    @id @default(cuid())
  content     String    @db.Text
  updatedAt   DateTime  @updatedAt
  updatedById String?
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("dashboard_changelog")
}

// --- ROLE PERMISSION PRESETS ---
// Omogućava "preset" permisije po roli (npr. CREW), koje se automatski dodeljuju pri kreiranju korisnika.
// Admin može menjati ove preset-e kroz UI.
model RolePermissionPreset {
  id             String   @id @default(cuid())
  role           Role     @unique
  permissionKeys String[] @default([])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// --- PDS ---
model PDSTemplate {
  id           String       @id @default(cuid())
  title        String       // Naziv PDS obrasca (npr. "PDS 2025")
  year         Int
  isGlobal     Boolean      @default(false) // true = svi restorani
  isActive     Boolean      @default(true)
  goals        Json         // Pitanja/ciljevi (PDSGoal[])
  scale        Json         // Skala ocjenjivanja (PDSScaleLevel[])
  restaurants  Restaurant[] // Ciljani restorani (prazno ako isGlobal)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([year])
}

model PDS {
  id                 String      @id @default(cuid())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId       String?
  restaurant         Restaurant? @relation(fields: [restaurantId], references: [id])
  managerId          String
  year               Int
  templateId         String?
  goals              Json
  scale              Json
  employeeComment    String?     @db.Text
  managerComment     String?     @db.Text
  employeeSignature  String?     @db.Text
  managerSignature   String?     @db.Text
  totalScore         Int         @default(0)
  finalGrade         String?
  status             PDSStatus   @default(DRAFT)

  @@unique([userId, year])
}


// --- RESTAURANTS ---
model Restaurant {
  id                  String               @id @default(cuid())
  code                String               @unique
  name                String?
  city                String?
  address             String?
  photoUrl            String?
  tagline             String?
  sitzplanPdfUrl      String?              // Legacy: jedan PDF (Vercel Blob URL)
  sitzplanPdfsData    Json                 @default("[]") // [{ "url", "fileName" }] do 5 PDF-ova (JSONB)
  isActive            Boolean              @default(true)
  openingHours        Json?                @default("{}")
  users               RestaurantUser[]
  departments         Department[]

  // Relacija na pravila
  rules               RuleRestaurant[]

  evaluations         EvaluationSubmission[]
  blockedDays         BlockedDay[]
  productivityReports ProductivityReport[]
  laborReports        LaborReport[]
  vacationRequests    VacationRequest[]
  pdsTemplates        PDSTemplate[] // Many-to-many: PDS obrasci koji ciljaju ovaj restoran
  pdsList             PDS[]
  visitReportCategories VisitReportCategory[]
  trainingPrograms    TrainingProgramRestaurant[]
  helpRequestsMade    HelpRequest[]        @relation("HelpRequestingRestaurant")
  helpSlotsProvided   HelpSlot[]           @relation("HelpProvidingRestaurant")
  aushilfeCustomSectors AushilfeCustomSector[]
  inventarSections    InventarSection[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model InventarSection {
  id           String         @id @default(cuid())
  restaurantId String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String         // "Produktion" | "Service" | "Lobby" | "McCafe"
  icon         String?        // Lucide icon name
  sortOrder    Int            @default(0)
  items        InventarItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([restaurantId])
}

model InventarItem {
  id               String          @id @default(cuid())
  sectionId        String
  section          InventarSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  geraet           String          // e.g. "Griller 1"
  marke            String?         // e.g. "Garland"
  modell           String?         // e.g. "MWE3S-1"
  seriennummer     String?
  anschaffungsjahr Int?
  garantieUrl      String?         // Vercel Blob URL
  garantieName     String?
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([sectionId])
}

model TrainingProgramRestaurant {
  programId    String
  restaurantId String
  program      TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@id([programId, restaurantId])
  @@index([programId])
  @@index([restaurantId])
}

model RestaurantUser {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  isPrimary    Boolean    @default(false)
  /** Redoslijed u Admin Urlaub tablici (DnD za SA/Admin/Architect), po restoranu */
  vacationListOrder Int   @default(0)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId, vacationListOrder])
}

// --- TOOLS ---
model ProductivityReport {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         String
  data         Json       @default("{}")
  targetProd   Float?     @default(120)
  netCoeff     Float?     @default(1.17)
  hourlyData   Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, date])
}

model LaborPlan {
  id         String   @id @default(cuid())
  year       Int
  month      Int
  restaurant String
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([year, month, restaurant])
}

model LaborReport {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  daysData     Json
  hourlyWage   Float      @default(11.80)
  budgetSales  Float      @default(0)
  budgetCost   Float      @default(0)

  /// CL: month finished — read-only until unlock grant or god-mode bypass
  clLocked                  Boolean   @default(false)
  clLockedAt                DateTime?
  clLockedByUserId          String?
  clLockedByUser            User?     @relation("LaborReportLockedBy", fields: [clLockedByUserId], references: [id], onDelete: SetNull)
  clUnlockRequestedAt       DateTime?
  clUnlockRequestedByUserId String?
  clUnlockRequestedByUser   User?     @relation("LaborReportUnlockRequestedBy", fields: [clUnlockRequestedByUserId], references: [id], onDelete: SetNull)
  /// Temporary edit right for requester after supervisor/architect approval
  clEditGrantUserId         String?
  clEditGrantUser           User?     @relation("LaborReportEditGrant", fields: [clEditGrantUserId], references: [id], onDelete: SetNull)
  clEditGrantUntil          DateTime?
  clUnlockRequestNote       String?   @db.Text

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, month, year])
  @@index([clLocked])
  @@index([clUnlockRequestedAt])
}

// Globalni praznici (Feiertage) – jedinstveno na nivou sajta, koriste Labor Planner i ostali moduli
model Holiday {
  id        String   @id @default(cuid())
  day       Int      // 1–31
  month     Int      // 1–12
  label     String?  // npr. "Neujahr"
  year      Int?     // null = svake godine; inače samo za tu godinu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VacationRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ✅ NOVO: kome ide odobrenje (snapshot nadređeni u momentu slanja)
  supervisorId String?
  supervisor   User?       @relation("VacationSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)

  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  start        String
  end          String
  days         Int
  status       String      @default("PENDING")
  note         String?     // opcionalna napomena (npr. za self-service admina ili razlog odbijanja)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([start])
  @@index([userId, start])
}

model BlockedDay {
  id           String     @id @default(cuid())
  date         String
  reason       String?
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model EvaluationTemplate {
  id          String                 @id @default(cuid())
  title       String
  criteria    Json
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  submissions EvaluationSubmission[]
}

model EvaluationSubmission {
  id           String             @id @default(cuid())
  templateId   String
  template     EvaluationTemplate @relation(fields: [templateId], references: [id])
  restaurantId String
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id])
  userId       String
  user         User               @relation(fields: [userId], references: [id])
