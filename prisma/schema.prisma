// --- BONUS TOOL MODELI ---

model BonusCycle {
  id          String            @id @default(cuid())
  name        String                                // npr. "2025 Godišnji Bonus"
  year        Int?
  description String?

  // Globalne postavke iz alata
  baseMonths  Float             @default(2)        // settings.baseMonths
  capPct      Int               @default(120)      // settings.capPct (0–120)
  factorMode  BonusFactorMode   @default(MULTIPLY) // settings.factorMode
  capFactor   Boolean           @default(true)     // settings.capFactor

  status      BonusCycleStatus  @default(DRAFT)
  isActive    Boolean           @default(false)    // brzi flag za "trenutni" ciklus

  // Relacije
  templates   BonusTemplate[]
  entries     BonusEntry[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([year, status])
  @@index([isActive])
}

// Definicija stubova/pillara i ciljeva po "odjelu" (RL, Office, AL)
model BonusTemplate {
  id          String      @id @default(cuid())
  cycleId     String
  cycle       BonusCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  // Logički odjel iz Bonus alata (RL, AL, Office ...)
  deptKey     String

  // Pillar ključ: "fin", "ops", "ind"
  pillarKey   String
  pillarName  String

  // Težina stubova – čuva se kao 0–1 (npr. 0.5 = 50%)
  pillarWeight Float     @default(0.0)

  enabled     Boolean    @default(true)

  // Relacija na pojedinačne ciljeve (goals)
  goals       BonusGoal[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([cycleId, deptKey])
  @@index([cycleId, deptKey, pillarKey])
}

model BonusGoal {
  id          String         @id @default(cuid())
  templateId  String
  template    BonusTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  name        String
  // Težina cilja u % (0–100), identično "w" iz HTML-a
  weightPct   Float          @default(0)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// Snapshot za svakog zaposlenika u datom ciklusu
model BonusEntry {
  id            String        @id @default(cuid())

  cycleId       String
  cycle         BonusCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot plate i postavki za taj ciklus (NE vezano za trenutni User profil)
  salaryMonthly Float         @default(0)      // Monatsgehalt
  baseMonths    Float         @default(0)      // može biti različito po korisniku

  // Pojedinačni faktori (kao u HTML state.factors)
  factorTenure  Float         @default(1.0)
  factorSize    Float         @default(1.0)
  factorOffice  Float         @default(1.0)

  // Fleksibilno polje za buduće faktore (npr. dodatni koeficijenti)
  factors       Json?         // { tenure, size, office, ... }

  // Izračunate ocjene (0–1.2) po stubu i ukupno
  scoreFin      Float         @default(0)
  scoreOps      Float         @default(0)
  scoreInd      Float         @default(0)
  scoreTotal    Float         @default(0)

  // Izračunata baza, limit i isplata
  amountBase    Float         @default(0)      // salary * baseMonths
  amountCap     Float         @default(0)      // base * capPct
  factorCombined Float        @default(1.0)    // rezultat factorFor(...)
  amountRaw     Float         @default(0)      // prije cap-a
  finalPayout   Float         @default(0)      // nakon cap-a (payout)

  // Snapshot ispunjenja ciljeva (fulfill.fin/ops/ind per-goal) za analitiku
  fulfillment   Json?         // { fin: number[], ops: number[], ind: number[] } ili detljaniji objekt

  isExcluded    Boolean       @default(false)  // npr. ako je zaposlenik izašao usred ciklusa

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([cycleId, userId])
  @@index([cycleId])
  @@index([userId])
}

// ─── Aushilfe (Ispomoć) ───────────────────────────────────────────────────────

model HelpRequest {
  id                     String                  @id @default(cuid())
  requestingRestaurantId String
  requestingRestaurant   Restaurant              @relation("HelpRequestingRestaurant", fields: [requestingRestaurantId], references: [id])
  date                   String                  // YYYY-MM-DD
  // Legacy fields – kept for backward compat with old rows only
  shiftTime              String?
  shiftNumber            Int                     @default(1)
  sectorKey              String                  @default("kueche")
  sectorLabel            String                  @default("Küche")
  neededSpots            Int                     @default(0)
  notes                  String?
  isArchived             Boolean                 @default(false)
  createdByUserId        String?
  createdByUser          User?                   @relation("HelpRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt              DateTime                @default(now())
  slots                  HelpSlot[]
  positions              HelpRequestPosition[]

  @@index([requestingRestaurantId])
  @@index([isArchived, date])
  @@index([createdByUserId])
}

model HelpRequestPosition {
  id            String      @id @default(cuid())
  helpRequestId String
  helpRequest   HelpRequest @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  sectorKey     String
  sectorLabel   String
  shiftTimeText String      // e.g. "Smjena 1 od 13:30 do 20:00"
  neededSpots   Int
  sortOrder     Int         @default(0)
  slots         HelpSlot[]

  @@index([helpRequestId])
}

model AushilfeCustomSector {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  key          String
  label        String
  group        String     @default("Sonstiges")
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, key])
  @@index([restaurantId])
}

model HelpSlot {
  id                    String               @id @default(cuid())
  helpRequestId         String
  helpRequest           HelpRequest          @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  positionId            String?
  position              HelpRequestPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  providingRestaurantId String
  providingRestaurant   Restaurant           @relation("HelpProvidingRestaurant", fields: [providingRestaurantId], references: [id])
  workerName            String
  providerManagerId     String?
  providerManager       User?                @relation("HelpSlotProviderManager", fields: [providerManagerId], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now())

  @@index([helpRequestId])
  @@index([positionId])
  @@index([providingRestaurantId])
  @@index([providerManagerId])
}

// Snapshot kompletnog Bonus state objekta (preneseno direktno iz HTML alata)
model BonusSheet {
  id        String   @id @default(cuid())
  name      String   // npr. "Obračun 2026 Q1"
  data      Json     // kompletan 'state' objekat iz alata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── GESPRÄCHSTHEMEN (neues Modell: Gespräch mit mehreren Themen) ────────────

enum ConversationStatus {
  OPEN
  ARCHIVED
}

model OneOnOneConversation {
  id               String                    @id @default(cuid())
  createdById      String?
  createdBy        User?                     @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  requesterUserId  String
  requester        User                      @relation("ConversationRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  supervisorUserId String
  supervisor       User                      @relation("ConversationSupervisor", fields: [supervisorUserId], references: [id], onDelete: Cascade)
  meetingDate      String?                   // YYYY-MM-DD, optional
  notes            String?                   @db.Text
  status           ConversationStatus        @default(OPEN)
  archivedAt       DateTime?
  archivedById     String?
  archivedBy       User?                     @relation("ConversationArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  items            OneOnOneConversationItem[]
  attachments      OneOnOneConversationAttachment[]
  todos            OneOnOneConversationTodoItem[]

  @@index([requesterUserId])
  @@index([supervisorUserId])
  @@index([status])
  @@index([createdById])
}

model OneOnOneConversationItem {
  id             String                @id @default(cuid())
  conversationId String
  conversation   OneOnOneConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?                 @relation("ConversationItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  title          String
  comment        String?               @db.Text
  sortOrder      Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  attachments    OneOnOneConversationAttachment[]
  comments       OneOnOneConversationItemComment[]

  @@index([conversationId, sortOrder])
  @@index([createdById])
}

model OneOnOneConversationItemComment {
  id        String                 @id @default(cuid())
  itemId    String
  item      OneOnOneConversationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  authorId  String
  author    User                   @relation("ConversationItemCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body      String                 @db.Text
  createdAt DateTime               @default(now())

  @@index([itemId, createdAt])
  @@index([authorId])
}

model OneOnOneConversationTodoItem {
  id             String               @id @default(cuid())
  conversationId String
  conversation   OneOnOneConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User                 @relation("ConversationTodoCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  title          String
  completed      Boolean              @default(false)
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([conversationId, sortOrder])
  @@index([createdById])
}

model OneOnOneConversationAttachment {
  id             String                     @id @default(cuid())
  conversationId String
  conversation   OneOnOneConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  itemId         String?
  item           OneOnOneConversationItem?  @relation(fields: [itemId], references: [id], onDelete: SetNull)
  uploadedById   String
  uploadedBy     User                       @relation("ConversationAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  fileUrl        String
  fileName       String
  fileType       String
  createdAt      DateTime                   @default(now())

  @@index([conversationId])
  @@index([itemId])
}

// ─── 1:1 TEME ZA RAZGOVOR (legacy) ───────────────────────────────────────────
enum OneOnOneTopicStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model OneOnOneTopic {
  id                       String               @id @default(cuid())
  createdByUserId          String
  createdBy                User                 @relation("TopicRequester", fields: [createdByUserId], references: [id], onDelete: Cascade)
  supervisorUserId         String
  supervisor               User                 @relation("TopicSupervisor", fields: [supervisorUserId], references: [id], onDelete: Cascade)
  title                    String
  details                  String?
  isUrgent                 Boolean              @default(false)
  status                   OneOnOneTopicStatus  @default(OPEN)
  supervisorNotes          String?
  agreedActions            String?
  isArchivedByRequester    Boolean              @default(false)
  isArchivedBySupervisor   Boolean              @default(false)
  resolvedAt               DateTime?

  // Meeting scheduling
  meetingStartsAt          DateTime?
  meetingEndsAt            DateTime?
  meetingLocation          String?
  requesterCalendarEventId String?
  supervisorCalendarEventId String?

  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  comments                 OneOnOneComment[]
  attachments              OneOnOneAttachment[]

  @@index([createdByUserId])
  @@index([supervisorUserId])
  @@index([meetingStartsAt])
  @@index([status])
}

model OneOnOneComment {
  id          String          @id @default(cuid())
  topicId     String
  topic       OneOnOneTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId    String
  author      User            @relation("OneOnOneCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String          @db.Text
  createdAt   DateTime        @default(now())

  attachments OneOnOneAttachment[]

  @@index([topicId, createdAt])
  @@index([authorId])
}

model OneOnOneAttachment {
  id           String           @id @default(cuid())
  topicId      String
  topic        OneOnOneTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  commentId    String?
  comment      OneOnOneComment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User             @relation("OneOnOneAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  fileUrl      String
  fileName     String
  fileType     String
  createdAt    DateTime         @default(now())

  @@index([topicId])
  @@index([commentId])
}
