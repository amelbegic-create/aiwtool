// --- MODULE: PRAVILA (NOVO - CMS VERZIJA) ---

// 1. Kategorije
model RuleCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  rules     Rule[]
  createdAt DateTime @default(now())
}

// 2. Slike (Galerija)
model RuleImage {
  id        String   @id @default(cuid())
  url       String
  ruleId    String
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

// 3. Glavni Rule model
model Rule {
  id            String           @id @default(cuid())
  title         String
  content       String?          @db.Text

  // Relacija na kategoriju
  categoryId    String
  category      RuleCategory     @relation(fields: [categoryId], references: [id])

  priority      RulePriority     @default(INFORMATION)

  // Status: Aktivan/Neaktivan
  isActive      Boolean          @default(true)
  status        RuleStatus       @default(ACTIVE) // Zadržano radi kompatibilnosti

  // Media
  videoUrl      String?

  // OVO JE KLJUČNO: Niz stringova za podršku više PDF-ova
  pdfUrls       String[]         @default([])

  imageUrl      String?          // Opcionalno za thumbnail

  // Relacija na slike (One-to-Many)
  images        RuleImage[]

  // Vidljivost
  isGlobal      Boolean          @default(true)

  authorId      String

  // Relacije
  restaurants   RuleRestaurant[]
  readReceipts  RuleReadReceipt[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

model RuleRestaurant {
  id           String     @id @default(cuid())
  ruleId       String
  restaurantId String
  rule         Rule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([ruleId, restaurantId])
}

model RuleReadReceipt {
  id        String   @id @default(cuid())
  ruleId    String
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([ruleId, userId])
}

//
// ✅ NOVO: TOOL STATE (Vercel Blob pointer per user + toolKey)
//
model ToolState {
  id        String   @id @default(cuid())
  toolKey   String
  blobUrl   String

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, toolKey])
  @@index([toolKey])
}

// Moduli označeni kao "dodani na dashboard" – prikazuju se u "Novi moduli"
model DashboardHighlight {
  id          String   @id @default(cuid())
  moduleKey   String   @unique  // npr. "rules", "vacations", "PDS"
  moduleLabel String   // npr. "Pravila & Procedure"
  addedAt     DateTime @default(now())
  order       Int      @default(0)  // manji = više gore

  @@index([addedAt])
}

/// Globalni dokumenti istaknuti na dashboardu (npr. \"Biblija AIW\") – samo URL + naslov.
model DashboardPinnedDoc {
  id        String   @id @default(cuid())
  key       String   @unique // stabilan identifikator (generisan), npr. \"doc_xxx\"
  title     String
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Slider „Novosti“ na dashboardu – cover + attachment (PDF ili slika)
model DashboardNewsItem {
  id               String                       @id @default(cuid())
  title            String
  subtitle         String?
  coverImageUrl    String
  attachmentUrl    String
  attachmentKind   DashboardNewsAttachmentKind
  sortOrder        Int                          @default(0)
  isActive         Boolean                      @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
