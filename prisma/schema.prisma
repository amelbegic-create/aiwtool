  @@index([newsItemId])
}

model DashboardEventView {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventItemId String
  eventItem    DashboardEventItem @relation(fields: [eventItemId], references: [id], onDelete: Cascade)
  viewedAt    DateTime        @default(now())

  @@unique([userId, eventItemId])
  @@index([eventItemId])
}

// --- FIRMEN & PARTNER (Dobavljači i servisi) ---
